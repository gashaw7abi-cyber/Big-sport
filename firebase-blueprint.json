{
  "entities": {
    "NewsPost": {
      "title": "NewsPost",
      "description": "A custom sports news article posted by the admin",
      "type": "object",
      "properties": {
        "headline": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "publishedAt": { "type": "number", "description": "Server timestamp" },
        "authorEmail": { "type": "string" },
        "published": { "type": "boolean" }
      },
      "required": ["headline", "description", "publishedAt", "authorEmail", "published"]
    },
    "Session": {
      "title": "Session",
      "description": "Active user session",
      "type": "object",
      "properties": {
        "lastActive": { "type": "number", "description": "Server timestamp" }
      },
      "required": ["lastActive"]
    }
  },
  "firestore": {
    "/customNews/{newsId}": {
      "schema": { "$ref": "#/entities/NewsPost" },
      "description": "Custom sports news added by the admin"
    },
    "/sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/Session" },
      "description": "Active user sessions for tracking online users"
    }
  }
}
